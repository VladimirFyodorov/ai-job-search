# ============================================================
# Hunter v2 — Job Search Assistant
# Copy to .env and fill in all values
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=          # Bot token from @BotFather
TELEGRAM_CHAT_ID=            # Vladimir's chat_id (admin + test)
TELEGRAM_ADMIN_CHAT_ID=      # Errors go here (Vladimir's chat_id)
TELEGRAM_SOFIA_CHAT_ID=      # Sofia's chat_id — set after she sends /start

# --- Notion ---
NOTION_TOKEN=                # ntn_... from Notion integration settings
NOTION_PARENT_PAGE_ID=       # ID of the parent page where databases will be created
# Populated by setup.py → config/notion_db_ids.json; kept here as fallback
NOTION_JOBS_DB_ID=
NOTION_APPLICATIONS_DB_ID=
NOTION_CONFIG_DB_ID=
NOTION_TEMPLATES_DB_ID=
NOTION_CV_PAGE_ID=

# --- OpenAI (Whisper for voice message transcription) ---
OPENAI_API_KEY=              # sk-... from platform.openai.com

# --- Job Scrapers ---
JOOBLE_API_KEY=              # free at jooble.org/api/about
SERPAPI_KEY=                 # free tier at serpapi.com (250 req/month)

# --- LaTeX ---
LATEX_ENGINE=lualatex        # lualatex (CV) or xelatex (cover letter)

# --- Docker / Cron (optional overrides) ---
# HUNTER_CONTAINER_NAME=hunter-v2-1   # used by daily_digest.py

# --- Telethon user auth (for bot testing) ---
# Run tools/test/tg_auth.py once to generate TG_SESSION
TG_API_ID=                   # from https://my.telegram.org → API development tools
TG_API_HASH=                 # from https://my.telegram.org → API development tools
TG_SESSION=                  # generated by tools/test/tg_auth.py
BOT_USERNAME=@Hunter_v2_bot
